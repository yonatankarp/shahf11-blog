---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { getAllPosts } from '../lib/posts';
import { withBase } from '../lib/url';
import { heroPhotoFile } from '../lib/hero';

const posts = await getAllPosts(); // oldest-first
const oldest = posts[0];
const total = posts.length;

// The home feed renders every post (oldest-first); a client script reveals a random handful
// each visit. Visitors without JS get the full archive list as a graceful fallback.
const FEATURED_COUNT = 4;

// A face portrait of Haya for the hero circle — see src/lib/hero.ts for how to swap it.
const heroPhoto = heroPhotoFile ? withBase(heroPhotoFile) : null;
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'חיה בסרט(ן)',
  url: new URL(withBase(''), Astro.site).href,
  inLanguage: 'he',
  author: { '@type': 'Person', name: 'חיה קרפ-צור' },
}).replace(/</g, '\\u003c');
---
<Base
  title="חיה בסרט(ן) — בלוג הזיכרון של חיה"
  description="ארכיון הבלוג 'חיה בסרט(ן)' מאת חיה, 2008–2009. מסע התמודדות עם סרטן השד, בהומור ובאומץ."
  ogImage={heroPhoto ?? undefined}
>
  <script type="application/ld+json" set:html={jsonLd} is:inline slot="head" />
  <script is:inline slot="head">document.documentElement.classList.add('js')</script>
  <style is:global>
    /* With JS, hide the full archive and let the script below reveal a random few. */
    html.js #home-recent .post-card:not(.is-shown) { display: none; }
  </style>
  <section class="home-hero">
    <p class="home-hero__eyebrow">בלוג הזיכרון של חיה</p>
    {heroPhoto && <img class="home-hero__photo" src={heroPhoto} alt="חיה" width="600" height="600" />}
    <h1 class="home-hero__title">חיה בסרט<span class="paren">(ן)</span></h1>
    <p class="home-hero__quote">הסרט שלי השנה: סרטן השד. האמונה שלי: השד לא נורא כל כך.</p>
    <p class="home-hero__ded">
      בין 2008 ל־2009 כתבה כאן חיה על המחלה — בהומור, בכעס ובאומץ. הבלוג נשמר כאן,
      {' '}{total} רשומות, בקולה שלה. לזכרה, ובאהבה, ממשפחתה.
    </p>
    <div class="home-hero__meta">
      <span dir="ltr">2008–2009</span><span class="dot" aria-hidden="true"></span><span>{total} רשומות</span>
    </div>
    {oldest && <a class="home-cta" href={withBase(`posts/${oldest.data.entryId}`)}>קראו מההתחלה</a>}
  </section>

  <section class="home-story" aria-label="על חיה">
    <p>באוגוסט 2007, בת 41, גילתה חיה שהיא חולה בסרטן השד. לאורך המחלה כתבה כאן בלוג — בהומור ובקלילות — כדי שחולים אחרים ימצאו את המידע בגובה העיניים שהיא עצמה התקשתה למצוא. בכתיבתה נגעה בעשרות חברים ברשת (לעיתים קראה לעצמה שחף). במאי 2010 נפטרה, לאחר מלחמה ארוכה במחלה.</p>
  </section>

  <section class="home-film">
    <div class="feed__head"><h2 class="disp">הסרט שלה</h2></div>
    <figure class="film">
      <video class="film__video" controls preload="metadata" poster={withBase('video/graduation-film-2009-poster.jpg')} aria-label="״חיה בסרט(ן)״ — סרט גמר, יוני 2009">
        <source src={withBase('video/graduation-film-2009.mp4')} type="video/mp4" />
        הדפדפן שלך אינו תומך בהפעלת וידאו.
      </video>
      <figcaption class="film__cap">״חיה בסרט(ן)״ — סרט גמר, יוני 2009</figcaption>
    </figure>
  </section>

  <section class="feed home-recent" id="home-recent">
    <div class="feed__head">
      <h2 class="disp">רשומות מהארכיון</h2>
      <a href={withBase('blog')}>כל הרשומות ←</a>
    </div>
    {posts.map((post) => <PostCard post={post} />)}
  </section>

  <script define:vars={{ featuredCount: FEATURED_COUNT }}>
    const section = document.getElementById('home-recent');
    if (section) {
      const cards = Array.from(section.querySelectorAll('.post-card'));
      const order = cards.map((_, i) => i);
      for (let i = order.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [order[i], order[j]] = [order[j], order[i]];
      }
      const chosen = new Set(order.slice(0, Math.min(featuredCount, cards.length)));
      // Cards stay in DOM (date) order; we only reveal the chosen ones.
      cards.forEach((card, i) => { if (chosen.has(i)) card.classList.add('is-shown'); });
    }
  </script>
</Base>
