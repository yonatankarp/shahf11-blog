---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { allTagsWithCounts } from '../../lib/tags';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const tags = await allTagsWithCounts();
  return tags.map((tag) => ({ params: { slug: tag.id }, props: { tag } }));
}
const { tag } = Astro.props;
---
<Base title={`${tag.label} — חיה בסרט(ן)`}>
  <div class="tag-page">
    <p class="eyebrow"><a href={withBase('tags')}>← כל התגיות</a></p>
    <h1 class="tag-page__title">{tag.label}</h1>
    <p class="eyebrow">{tag.count} רשומות</p>
    <div class="feed">
      {tag.posts.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</Base>
