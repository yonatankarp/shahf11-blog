---
import '@fontsource-variable/frank-ruhl-libre';
import '@fontsource-variable/assistant';
import '@fontsource/secular-one/400.css';
import '@fontsource/gveret-levin/400.css';
import '@fontsource/heebo/700.css';
import '../styles/global.css';
import { withBase } from '../lib/url';
const { title, description, wide = false } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '');
const isActive = (href) => {
  const clean = withBase(href).replace(/\/$/, '');
  if (href === '/') return path === clean || path === withBase('').replace(/\/$/, '');
  return path === clean || path.startsWith(clean + '/');
};
const nav = [
  { href: '/', label: 'בית' },
  { href: 'blog', label: 'הבלוג' },
  { href: 'tags', label: 'חיפוש' },
  { href: 'gallery', label: 'גלריה' },
  { href: 'about', label: 'על הבלוג' },
];
---
<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <a class="skip-link" href="#main">דלגו לתוכן</a>
    <header class="site-nav-bar">
      <a class="site-nav-bar__brand" href={withBase('/')}>חיה בסרט<span class="paren">(ן)</span></a>
      <nav class="site-links" aria-label="ניווט ראשי">
        {nav.map((n) => (
          <a href={withBase(n.href)} aria-current={isActive(n.href) ? 'page' : undefined}>{n.label}</a>
        ))}
      </nav>
    </header>
    <main id="main" class:list={['wrap', { 'wrap--wide': wide }]}><slot /></main>
    <footer class="site-footer">
      ארכיון הבלוג של חיה · <a href={withBase('about')}>על הבלוג</a> · <a href="https://github.com/yonatankarp/shahf11-blog">GitHub</a>
    </footer>
  </body>
</html>
